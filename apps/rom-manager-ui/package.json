{
  "name": "rom-manager-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "test": "npx playwright test",
    "test:api": "bash server/test-api.sh",
    "test:nps": "node --test server/test-nps.mjs",
    "test:cache": "node --test server/test-cache.mjs",
    "test:version-sort": "node --test server/test-version-sort.mjs",
    "test:ui": "npx playwright test",
    "electron:dev": "concurrently \"node server/index.js\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.0",
    "@mui/material": "^9.1.0",
    "@uiw/react-md-editor": "^4.1.1",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "playwright": "^1.60.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
